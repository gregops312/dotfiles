#!/usr/bin/env bash

# EX: ./install -w

set -eu
# set -x

mapfile -t CONFIGS < <(ls conf)
WORK=false

install_helix() {
  if ! command -v hx > /dev/null 2>&1; then
    if [[ $(uname) == "Darwin" ]]; then
      brew install helix
    elif [[ $(uname) == "Linux" ]]; then
      sudo add-apt-repository --yes ppa:maveonair/helix-editor
      sudo apt-get update -y > /dev/null
      sudo apt-get install -y helix > /dev/null
    fi
  fi
}

install_oh_my_zsh() {
  if ! [[ -d "${HOME}/.oh-my-zsh" ]]; then
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended  > /dev/null
  fi
}

install_starship() {
  if ! command -v starship > /dev/null 2>&1; then
    if [[ $(uname) == "Darwin" ]]; then
      brew install starship
    elif [[ $(uname) == "Linux" ]]; then
      sudo apt-get update -y > /dev/null
      sudo apt-get install -y starship > /dev/null
    fi
  fi
}

install_vim_vundle() {
  if ! [[  -d "${HOME}/.vim/bundle/Vundle.vim" ]]; then
    git clone --quiet https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim
  fi
}

sym_link() {
  echo "ln -s \"${1}\" \"${2}\""
  ln -s "${1}" "${2}"
}

noisy_link() {
  echo "ln \"${1}\" \"${2}\""
  ln "${1}" "${2}"
}

check_link() {
  if ! [[ -e "${2}" ]]; then
    noisy_link "${1}" "${2}"
  else
    if [[ $(uname) == "Darwin" ]]; then
      if [[ $(stat -f '%l' "${2}") -eq 2 ]]; then
        echo "linked:skipped: ${2}"
      # If file exists
      elif [[ -e "${2}" ]]; then
        echo "not-linked:exists:skipped: rm -rf ${2}"
      fi
    elif [[ $(uname) == "Linux" ]]; then
      if [[ $(stat --format '%h' "${2}") -eq 2 ]]; then
        echo "linked:skipped: ${2}"
      elif [[ -e "${2}" ]]; then
        echo "not-linked:exists:skipped: rm -rf ${2}"
      fi
    else
      echo "Unsupported OS: $(uname)"
      exit 1
    fi
  fi
}

check_sym_link() {
  if ! [[ -e ${2} ]]; then
    sym_link "${1}" "${2}"
  elif [[ -L ${2} ]];then
    echo "linked:skipped: ${2}"
  else
    echo "not-linked:exists:skipped: rm -rf ${2}"
  fi
}

options() {
  while getopts ":w" opt; do
    case "${opt}" in
      w)
        WORK=true;;
      *)
        usage;;
    esac
  done
}

vim_setup() {
  install_vim_vundle
  mkdir -p "${HOME}"/.vim/colors
  vim --clean '+source ~/.vimrc' +PluginInstall +qall

  # shellcheck disable=SC2144
  if [[ -f "${HOME}"/.vim/bundle/vim-colorschemes/colors/* ]]; then
   mv "${HOME}"/.vim/bundle/vim-colorschemes/colors/* \
    "${HOME}"/.vim/colors
  fi

  # shellcheck disable=SC2144
  if [[ -f "${HOME}"/.vim/bundle/vim-railscasts-theme/colors/* ]]; then
    mv "${HOME}"/.vim/bundle/vim-railscasts-theme/colors/* \
      "${HOME}"/.vim/colors
  fi
}

main() {
  options "$@"
  # install_helix
  install_oh_my_zsh
  install_starship

  # Hard link all config files
  for i in "${CONFIGS[@]}"; do
    if [[ "${i}" == *"greg-kman.zsh-theme"* ]]; then
      check_link  "conf/${i}" "${HOME}/.oh-my-zsh/themes/greg-kman.zsh-theme"
      continue
    fi
    if [[ "${i}" == *"starship.toml"* ]]; then
      mkdir -p "${HOME}/.config"
      check_link  "conf/${i}" "${HOME}/.config/starship.toml"
      continue
    fi
    check_link "conf/${i}" "${HOME}/.${i}"
  done

  vim_setup
  check_sym_link "${PWD}/bin" "${HOME}/bin"

  if $WORK; then
    # shellcheck disable=SC2016
    grep -qxF 'export PATH="$HOME/bin-work:$PATH"' conf/zshrc || echo 'export PATH="$HOME/bin-work:$PATH"' >> conf/zshrc
    grep -qxF 'source ~/.zshrc-work' conf/zshrc || echo 'source ~/.zshrc-work' >> conf/zshrc
  fi
  # shellcheck disable=SC1090
  # source ~/.zshrc
  [[ $- == *i* ]] && source ~/.zshrc || true
}

usage() {
  cat <<EOF
  Usage: $(basename "$0") [-w]
    -w: Is this a work machine?
EOF
  exit 1
}

main "$@"
